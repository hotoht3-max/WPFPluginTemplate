<tsd:PluginWindowBase
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Apibim.Plugins.BuiltUpColumn"
        xmlns:tsd="clr-namespace:Tekla.Structures.Dialog;assembly=Tekla.Structures.Dialog"
        xmlns:UIControls="clr-namespace:Tekla.Structures.Dialog.UIControls;assembly=Tekla.Structures.Dialog" 
        x:Class="Apibim.Plugins.BuiltUpColumn.MainWindow"
        mc:Ignorable="d"
        Title="Сквозная колонна RAM (Alpha)" FontSize="14" Height="800" Width="550">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <UIControls:WpfSaveLoad Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.Resources>
                    <Style TargetType="TextBox">
                        <Setter Property="Height" Value="24"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0,3,5,3"/>
                    </Style>
                    <Style TargetType="ComboBox">
                        <Setter Property="Height" Value="24"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0,3,5,3"/>
                    </Style>
                    <Style TargetType="Label">
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0,3,5,3"/>
                    </Style>
                    <Style TargetType="UIControls:WpfFilterCheckBox">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="10,0"/>
                    </Style>
                </Grid.Resources>

                <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="Габариты и ориентация" FontWeight="Bold" Margin="0,10,0,5"/>

                <UIControls:WpfFilterCheckBox Grid.Row="1" Grid.Column="0" AttributeName="Bcol"/>
                <Label Grid.Row="1" Grid.Column="1" Content="Ширина колонны (Bcol):"/>
                <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Bcol}"/>

                <UIControls:WpfFilterCheckBox Grid.Row="2" Grid.Column="0" AttributeName="Br_Rot"/>
                <Label Grid.Row="2" Grid.Column="1" Content="Поворот ветвей (Br_Rot):"/>
                <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding Br_Rot}"/>

                <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Text="Высотные отметки" FontWeight="Bold" Margin="0,10,0,5"/>

                <UIControls:WpfFilterCheckBox Grid.Row="4" Grid.Column="0" AttributeName="Hcol_1"/>
                <Label Grid.Row="4" Grid.Column="1" Content="Высота ветви вверх (Hcol_1):"/>
                <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding Hcol_1}"/>

                <UIControls:WpfFilterCheckBox Grid.Row="5" Grid.Column="0" AttributeName="Hcol_e1"/>
                <Label Grid.Row="5" Grid.Column="1" Content="Глубина ветви вниз (Hcol_e1):"/>
                <TextBox Grid.Row="5" Grid.Column="2" Text="{Binding Hcol_e1}"/>

                <UIControls:WpfFilterCheckBox Grid.Row="6" Grid.Column="0" AttributeName="Hcol_e2"/>
                <Label Grid.Row="6" Grid.Column="1" Content="Свободная зона снизу (Hcol_e2):"/>
                <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding Hcol_e2}"/>

                <UIControls:WpfFilterCheckBox Grid.Row="7" Grid.Column="0" AttributeName="Hcol_e3"/>
                <Label Grid.Row="7" Grid.Column="1" Content="Свободная зона сверху (Hcol_e3):"/>
                <TextBox Grid.Row="7" Grid.Column="2" Text="{Binding Hcol_e3}"/>

                <TextBlock Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Text="Параметры решетки" FontWeight="Bold" Margin="0,10,0,5"/>

                <UIControls:WpfFilterCheckBox Grid.Row="9" Grid.Column="0" AttributeName="Hr_base"/>
                <Label Grid.Row="9" Grid.Column="1" Content="Базовый шаг решетки (Hr_base):"/>
                <TextBox Grid.Row="9" Grid.Column="2" Text="{Binding Hr_base}"/>

                <UIControls:WpfFilterCheckBox Grid.Row="10" Grid.Column="0" AttributeName="L_Rasc"/>
                <Label Grid.Row="10" Grid.Column="1" Content="Расцентровка (L_Rasc):"/>
                <TextBox Grid.Row="10" Grid.Column="2" Text="{Binding L_Rasc}"/>

                <UIControls:WpfFilterCheckBox Grid.Row="11" Grid.Column="0" AttributeName="L_Type"/>
                <Label Grid.Row="11" Grid.Column="1" Content="Тип решетки (L_Type):"/>
                <ComboBox Grid.Row="11" Grid.Column="2" SelectedIndex="{Binding L_Type}">
                    <ComboBoxItem Content="0 - Одинарная (по центру)"/>
                    <ComboBoxItem Content="1 - Сдвоенная (две плоскости)"/>
                </ComboBox>

                <UIControls:WpfFilterCheckBox Grid.Row="12" Grid.Column="0" AttributeName="L_Preset"/>
                <Label Grid.Row="12" Grid.Column="1" Content="Вариант решетки (Preset):"/>
                <ComboBox Grid.Row="12" Grid.Column="2" SelectedIndex="{Binding L_Preset}">
                    <ComboBoxItem Content="0 - Не используется" Visibility="Collapsed"/>
                    <ComboBoxItem Content="1 - Полка по оси"/>
                    <ComboBoxItem Content="2 - Уголок по обушку (Слева)"/>
                    <ComboBoxItem Content="3 - Труба (По центру)"/>
                </ComboBox>

                <UIControls:WpfFilterCheckBox Grid.Row="13" Grid.Column="0" AttributeName="L_Offset"/>
                <Label Grid.Row="13" Grid.Column="1" Content="Доп. смещение решетки (L_Offset):"/>
                <TextBox Grid.Row="13" Grid.Column="2" Text="{Binding L_Offset}"/>

                <TextBlock Grid.Row="14" Grid.Column="1" Grid.ColumnSpan="2" Text="Поперечные планки (Struts)" FontWeight="Bold" Margin="0,10,0,5"/>

                <UIControls:WpfFilterCheckBox Grid.Row="15" Grid.Column="0" AttributeName="S_Preset"/>
                <Label Grid.Row="15" Grid.Column="1" Content="Настройка планок (S_Preset):"/>
                <ComboBox Grid.Row="15" Grid.Column="2" SelectedIndex="{Binding S_Preset}">
                    <ComboBoxItem Content="0 - Нет (Не создавать)"/>
                    <ComboBoxItem Content="1 - Как решетка (Полный клон)"/>
                    <ComboBoxItem Content="2 - Швеллер (Одинарный, корытом)"/>
                </ComboBox>

                <TextBlock Grid.Row="16" Grid.Column="1" Grid.ColumnSpan="2" Text="Профили и материалы" FontWeight="Bold" Margin="0,10,0,5"/>

                <UIControls:WpfFilterCheckBox Grid.Row="17" Grid.Column="0" AttributeName="BranchProfile"/>
                <Label Grid.Row="17" Grid.Column="1" Content="Профиль ветвей:"/>
                <TextBox Grid.Row="17" Grid.Column="2" Text="{Binding BranchProfile}"/>
                <UIControls:WpfProfileCatalog x:Name="BranchProfileCatalog" Grid.Row="17" Grid.Column="3" Width="30" Margin="0,3,0,3"
                                              SelectClicked="BranchProfileCatalog_SelectClicked" SelectionDone="BranchProfileCatalog_SelectionDone"/>

                <UIControls:WpfFilterCheckBox Grid.Row="18" Grid.Column="0" AttributeName="LacingProfile"/>
                <Label Grid.Row="18" Grid.Column="1" Content="Профиль решетки:"/>
                <TextBox Grid.Row="18" Grid.Column="2" Text="{Binding LacingProfile}"/>
                <UIControls:WpfProfileCatalog x:Name="LacingProfileCatalog" Grid.Row="18" Grid.Column="3" Width="30" Margin="0,3,0,3"
                                              SelectClicked="LacingProfileCatalog_SelectClicked" SelectionDone="LacingProfileCatalog_SelectionDone"/>

                <UIControls:WpfFilterCheckBox Grid.Row="19" Grid.Column="0" AttributeName="S_Profile"/>
                <Label Grid.Row="19" Grid.Column="1" Content="Профиль планок:"/>
                <TextBox Grid.Row="19" Grid.Column="2" Text="{Binding S_Profile}"/>
                <UIControls:WpfProfileCatalog x:Name="StrutProfileCatalog" Grid.Row="19" Grid.Column="3" Width="30" Margin="0,3,0,3"
                                              SelectClicked="StrutProfileCatalog_SelectClicked" SelectionDone="StrutProfileCatalog_SelectionDone"/>

                <UIControls:WpfFilterCheckBox Grid.Row="20" Grid.Column="0" AttributeName="Material"/>
                <Label Grid.Row="20" Grid.Column="1" Content="Материал ветвей/решетки:"/>
                <TextBox Grid.Row="20" Grid.Column="2" Text="{Binding Material}"/>
                <UIControls:WpfMaterialCatalog x:Name="MaterialCatalog" Grid.Row="20" Grid.Column="3" Width="30" Margin="0,3,0,3"
                                               SelectClicked="MaterialCatalog_SelectClicked" SelectionDone="MaterialCatalog_SelectionDone"/>

                <UIControls:WpfFilterCheckBox Grid.Row="21" Grid.Column="0" AttributeName="S_Material"/>
                <Label Grid.Row="21" Grid.Column="1" Content="Материал планок:"/>
                <TextBox Grid.Row="21" Grid.Column="2" Text="{Binding S_Material}"/>
                <UIControls:WpfMaterialCatalog x:Name="StrutMaterialCatalog" Grid.Row="21" Grid.Column="3" Width="30" Margin="0,3,0,3"
                                               SelectClicked="StrutMaterialCatalog_SelectClicked" SelectionDone="StrutMaterialCatalog_SelectionDone"/>
            </Grid>
        </ScrollViewer>

        <UIControls:WpfOkApplyModifyGetOnOffCancel Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
            ApplyClicked="WpfOkApplyModifyGetOnOffCancel_ApplyClicked" 
            CancelClicked="WpfOkApplyModifyGetOnOffCancel_CancelClicked" 
            GetClicked="WpfOkApplyModifyGetOnOffCancel_GetClicked" 
            ModifyClicked="WpfOkApplyModifyGetOnOffCancel_ModifyClicked" 
            OkClicked="WpfOkApplyModifyGetOnOffCancel_OkClicked" 
            OnOffClicked="WpfOkApplyModifyGetOnOffCancel_OnOffClicked"/>
    </Grid>
</tsd:PluginWindowBase>