<tsd:PluginWindowBase
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Apibim.Tekla.Plugins.BuiltUpColumn"
        xmlns:tsd="clr-namespace:Tekla.Structures.Dialog;assembly=Tekla.Structures.Dialog"
        xmlns:UIControls="clr-namespace:Tekla.Structures.Dialog.UIControls;assembly=Tekla.Structures.Dialog" 
        x:Class="Apibim.Tekla.Plugins.BuiltUpColumn.MainWindow"
        mc:Ignorable="d"
        Title="Сквозная колонна (Apibim)" FontSize="14" Height="480" Width="450">

    <tsd:PluginWindowBase.DataContext>
        <local:MainWindowViewModel/>
    </tsd:PluginWindowBase.DataContext>

    <Grid>
        <Grid.Resources>
            <Style TargetType="TextBox">
                <Setter Property="Height" Value="24"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style TargetType="Label">
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style TargetType="UIControls:WpfFilterCheckBox">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="10,0"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <UIControls:WpfSaveLoad Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <UIControls:WpfFilterCheckBox Grid.Row="0" Grid.Column="0" AttributeName="TopExtension"/>
            <Label Grid.Row="0" Grid.Column="1" Content="Верхний вылет ветви (мм):"/>
            <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding TopExtension}" Margin="0,5"/>

            <UIControls:WpfFilterCheckBox Grid.Row="1" Grid.Column="0" AttributeName="BottomExtension"/>
            <Label Grid.Row="1" Grid.Column="1" Content="Нижний вылет ветви (мм):"/>
            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding BottomExtension}" Margin="0,5"/>

            <UIControls:WpfFilterCheckBox Grid.Row="2" Grid.Column="0" AttributeName="LacingBottomClearance"/>
            <Label Grid.Row="2" Grid.Column="1" Content="Свободная зона снизу (мм):"/>
            <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding LacingBottomClearance}" Margin="0,5"/>

            <UIControls:WpfFilterCheckBox Grid.Row="3" Grid.Column="0" AttributeName="LacingTopClearance"/>
            <Label Grid.Row="3" Grid.Column="1" Content="Свободная зона сверху (мм):"/>
            <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding LacingTopClearance}" Margin="0,5"/>

            <UIControls:WpfFilterCheckBox Grid.Row="4" Grid.Column="0" AttributeName="TargetLacingStep"/>
            <Label Grid.Row="4" Grid.Column="1" Content="Базовый шаг решетки (мм):" FontWeight="Bold"/>
            <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding TargetLacingStep}" Margin="0,5" FontWeight="Bold"/>

            <UIControls:WpfFilterCheckBox Grid.Row="6" Grid.Column="0" AttributeName="BranchProfile"/>
            <Label Grid.Row="6" Grid.Column="1" Content="Профиль ветвей:"/>
            <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding BranchProfile}" Margin="0,5"/>

            <UIControls:WpfFilterCheckBox Grid.Row="7" Grid.Column="0" AttributeName="LacingProfile"/>
            <Label Grid.Row="7" Grid.Column="1" Content="Профиль решетки:"/>
            <TextBox Grid.Row="7" Grid.Column="2" Text="{Binding LacingProfile}" Margin="0,5"/>

            <UIControls:WpfFilterCheckBox Grid.Row="8" Grid.Column="0" AttributeName="Material"/>
            <Label Grid.Row="8" Grid.Column="1" Content="Материал:"/>
            <TextBox Grid.Row="8" Grid.Column="2" Text="{Binding Material}" Margin="0,5"/>
        </Grid>

        <UIControls:WpfOkApplyModifyGetOnOffCancel Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
            ApplyClicked="WpfOkApplyModifyGetOnOffCancel_ApplyClicked" 
            CancelClicked="WpfOkApplyModifyGetOnOffCancel_CancelClicked" 
            GetClicked="WpfOkApplyModifyGetOnOffCancel_GetClicked" 
            ModifyClicked="WpfOkApplyModifyGetOnOffCancel_ModifyClicked" 
            OkClicked="WpfOkApplyModifyGetOnOffCancel_OkClicked" 
            OnOffClicked="WpfOkApplyModifyGetOnOffCancel_OnOffClicked"/>
    </Grid>
</tsd:PluginWindowBase>