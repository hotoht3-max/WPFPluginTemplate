<tsd:PluginWindowBase
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Apibim.Plugins.BuiltUpColumn"
        xmlns:tsd="clr-namespace:Tekla.Structures.Dialog;assembly=Tekla.Structures.Dialog"
        xmlns:UIControls="clr-namespace:Tekla.Structures.Dialog.UIControls;assembly=Tekla.Structures.Dialog" 
        x:Class="Apibim.Plugins.BuiltUpColumn.MainWindow"
        mc:Ignorable="d"
        Title="Сквозная колонна RAM (Alpha)" FontSize="14" Height="700" Width="550">

    <Grid>
        <Grid.Resources>
            <Style TargetType="TextBox">
                <Setter Property="Height" Value="24"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,3,5,3"/>
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="Height" Value="24"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,3,5,3"/>
            </Style>
            <Style TargetType="Label">
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,3,5,3"/>
            </Style>
            <Style TargetType="UIControls:WpfFilterCheckBox">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="10,0"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <UIControls:WpfSaveLoad Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,5,0,5"/>

        <TabControl Grid.Row="1" Margin="5">

            <TabItem Header="Общее">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="Габариты и ориентация" FontWeight="Bold" Margin="0,10,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="1" Grid.Column="0" AttributeName="Bcol"/>
                        <Label Grid.Row="1" Grid.Column="1" Content="Ширина колонны (Bcol):"/>
                        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Bcol}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="2" Grid.Column="0" AttributeName="Br_Rot"/>
                        <Label Grid.Row="2" Grid.Column="1" Content="Поворот ветвей (Br_Rot):"/>
                        <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding Br_Rot}"/>

                        <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Text="Высотные отметки" FontWeight="Bold" Margin="0,15,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="4" Grid.Column="0" AttributeName="Hcol_1"/>
                        <Label Grid.Row="4" Grid.Column="1" Content="Высота ветви вверх (Hcol_1):"/>
                        <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding Hcol_1}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="5" Grid.Column="0" AttributeName="Hcol_e1"/>
                        <Label Grid.Row="5" Grid.Column="1" Content="Глубина ветви вниз (Hcol_e1):"/>
                        <TextBox Grid.Row="5" Grid.Column="2" Text="{Binding Hcol_e1}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="6" Grid.Column="0" AttributeName="Hcol_e2"/>
                        <Label Grid.Row="6" Grid.Column="1" Content="Свободная зона снизу (Hcol_e2):"/>
                        <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding Hcol_e2}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="7" Grid.Column="0" AttributeName="Hcol_e3"/>
                        <Label Grid.Row="7" Grid.Column="1" Content="Свободная зона сверху (Hcol_e3):"/>
                        <TextBox Grid.Row="7" Grid.Column="2" Text="{Binding Hcol_e3}"/>

                        <TextBlock Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Text="Стыки ветвей" FontWeight="Bold" Margin="0,15,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="9" Grid.Column="0" AttributeName="SplicesText"/>
                        <Label Grid.Row="9" Grid.Column="1" Content="Отметки стыков (от низа):"/>
                        <TextBox Grid.Row="9" Grid.Column="2" Text="{Binding SplicesText}"/>

                        <TextBlock Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" Text="Профиль ветви" FontWeight="Bold" Margin="0,15,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="11" Grid.Column="0" AttributeName="BranchProfile"/>
                        <Label Grid.Row="11" Grid.Column="1" Content="Профиль ветвей:"/>
                        <TextBox Grid.Row="11" Grid.Column="2" Text="{Binding BranchProfile}"/>
                        <UIControls:WpfProfileCatalog x:Name="BranchProfileCatalog" Grid.Row="11" Grid.Column="3" Width="30" Margin="0,3,0,3"
                                                      SelectClicked="BranchProfileCatalog_SelectClicked" SelectionDone="BranchProfileCatalog_SelectionDone"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="12" Grid.Column="0" AttributeName="Material"/>
                        <Label Grid.Row="12" Grid.Column="1" Content="Материал колонны:"/>
                        <TextBox Grid.Row="12" Grid.Column="2" Text="{Binding Material}"/>
                        <UIControls:WpfMaterialCatalog x:Name="MaterialCatalog" Grid.Row="12" Grid.Column="3" Width="30" Margin="0,3,0,3"
                                                       SelectClicked="MaterialCatalog_SelectClicked" SelectionDone="MaterialCatalog_SelectionDone"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Решетка">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="Разбивка панелей" FontWeight="Bold" Margin="0,10,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="1" Grid.Column="0" AttributeName="L_StepMode"/>
                        <Label Grid.Row="1" Grid.Column="1" Content="Режим шага решетки:"/>
                        <ComboBox Grid.Row="1" Grid.Column="2" SelectedIndex="{Binding L_StepMode}">
                            <ComboBoxItem Content="0 - Равномерный"/>
                            <ComboBoxItem Content="1 - Ввод размеров (Массив)"/>
                            <ComboBoxItem Content="2 - Кол-во панелей и отметки"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="2" Grid.Column="0" AttributeName="Hr_base"/>
                        <Label Grid.Row="2" Grid.Column="1" Content="Базовый шаг (Для 0 режима):"/>
                        <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding Hr_base}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="3" Grid.Column="0" AttributeName="L_StepText"/>
                        <Label Grid.Row="3" Grid.Column="1" Content="Массив / Отметки:"/>
                        <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding L_StepText}"/>

                        <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Text="Расцентровка узлов" FontWeight="Bold" Margin="0,15,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="5" Grid.Column="0" AttributeName="L_Rasc"/>
                        <Label Grid.Row="5" Grid.Column="1" Content="Базовая расцентровка (L_Rasc):"/>
                        <TextBox Grid.Row="5" Grid.Column="2" Text="{Binding L_Rasc}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="6" Grid.Column="0" AttributeName="L_Rasc_Base"/>
                        <Label Grid.Row="6" Grid.Column="1" Content="Расцентровка базы (Узел 1):"/>
                        <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding L_Rasc_Base}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="7" Grid.Column="0" AttributeName="L_Rasc_Top"/>
                        <Label Grid.Row="7" Grid.Column="1" Content="Расцентровка верха (Узел N):"/>
                        <TextBox Grid.Row="7" Grid.Column="2" Text="{Binding L_Rasc_Top}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="8" Grid.Column="0" AttributeName="L_RascOverrides"/>
                        <Label Grid.Row="8" Grid.Column="1" Content="Исключения (Узел:Вверх/Вниз):"/>
                        <TextBox Grid.Row="8" Grid.Column="2" Text="{Binding L_RascOverrides}"/>

                        <TextBlock Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2" Text="Параметры и позиционирование" FontWeight="Bold" Margin="0,15,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="10" Grid.Column="0" AttributeName="L_Type"/>
                        <Label Grid.Row="10" Grid.Column="1" Content="Тип решетки:"/>
                        <ComboBox Grid.Row="10" Grid.Column="2" SelectedIndex="{Binding L_Type}">
                            <ComboBoxItem Content="0 - Одинарная"/>
                            <ComboBoxItem Content="1 - Сдвоенная"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="11" Grid.Column="0" AttributeName="L_Preset"/>
                        <Label Grid.Row="11" Grid.Column="1" Content="Вариант (Пресет):"/>
                        <ComboBox Grid.Row="11" Grid.Column="2" SelectedIndex="{Binding L_Preset}">
                            <ComboBoxItem Content="0 - Не используется" Visibility="Collapsed"/>
                            <ComboBoxItem Content="1 - Полка по оси"/>
                            <ComboBoxItem Content="2 - Уголок по обушку (Слева)"/>
                            <ComboBoxItem Content="3 - Труба (По центру)"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="12" Grid.Column="0" AttributeName="L_Offset"/>
                        <Label Grid.Row="12" Grid.Column="1" Content="Доп. смещение:"/>
                        <TextBox Grid.Row="12" Grid.Column="2" Text="{Binding L_Offset}"/>

                        <TextBlock Grid.Row="13" Grid.Column="1" Grid.ColumnSpan="2" Text="Профиль решетки" FontWeight="Bold" Margin="0,15,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="14" Grid.Column="0" AttributeName="LacingProfile"/>
                        <Label Grid.Row="14" Grid.Column="1" Content="Профиль раскоса:"/>
                        <TextBox Grid.Row="14" Grid.Column="2" Text="{Binding LacingProfile}"/>
                        <UIControls:WpfProfileCatalog x:Name="LacingProfileCatalog" Grid.Row="14" Grid.Column="3" Width="30" Margin="0,3,0,3"
                                                      SelectClicked="LacingProfileCatalog_SelectClicked" SelectionDone="LacingProfileCatalog_SelectionDone"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Планки">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="Настройки планок по зонам" FontWeight="Bold" Margin="0,10,0,5"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="1" Grid.Column="0" AttributeName="S_Base_Preset"/>
                        <Label Grid.Row="1" Grid.Column="1" Content="Планка в базе [Узел 1]:"/>
                        <ComboBox Grid.Row="1" Grid.Column="2" SelectedIndex="{Binding S_Base_Preset}">
                            <ComboBoxItem Content="0 - Нет"/>
                            <ComboBoxItem Content="1 - Распорка (дублер)"/>
                            <ComboBoxItem Content="2 - Диафрагма (швеллер)"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="2" Grid.Column="0" AttributeName="S_Top_Preset"/>
                        <Label Grid.Row="2" Grid.Column="1" Content="Планка в верхушке [Узел N]:"/>
                        <ComboBox Grid.Row="2" Grid.Column="2" SelectedIndex="{Binding S_Top_Preset}">
                            <ComboBoxItem Content="0 - Нет"/>
                            <ComboBoxItem Content="1 - Распорка (дублер)"/>
                            <ComboBoxItem Content="2 - Диафрагма (швеллер)"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="3" Grid.Column="0" AttributeName="S_Splice_Preset"/>
                        <Label Grid.Row="3" Grid.Column="1" Content="Планки у стыков ветвей:"/>
                        <ComboBox Grid.Row="3" Grid.Column="2" SelectedIndex="{Binding S_Splice_Preset}">
                            <ComboBoxItem Content="0 - Нет"/>
                            <ComboBoxItem Content="1 - Распорка (дублер)"/>
                            <ComboBoxItem Content="2 - Диафрагма (швеллер)"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="4" Grid.Column="0" AttributeName="S_Preset"/>
                        <Label Grid.Row="4" Grid.Column="1" Content="Рядовые планки (по умолчанию):"/>
                        <ComboBox Grid.Row="4" Grid.Column="2" SelectedIndex="{Binding S_Preset}">
                            <ComboBoxItem Content="0 - Нет"/>
                            <ComboBoxItem Content="1 - Распорка (дублер)"/>
                            <ComboBoxItem Content="2 - Диафрагма (швеллер)"/>
                        </ComboBox>

                        <TextBlock Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Text="Правила ручного управления" FontWeight="Bold" Margin="0,15,0,5"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="6" Grid.Column="0" AttributeName="S_Mode"/>
                        <Label Grid.Row="6" Grid.Column="1" Content="Режим генерации:"/>
                        <ComboBox Grid.Row="6" Grid.Column="2" SelectedIndex="{Binding S_Mode}">
                            <ComboBoxItem Content="0 - Выключить ручной ввод"/>
                            <ComboBoxItem Content="1 - Точечный (Только указанные)"/>
                            <ComboBoxItem Content="2 - Сплошной (С исключениями)"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="7" Grid.Column="0" AttributeName="S_NodesDouble"/>
                        <Label Grid.Row="7" Grid.Column="1" Content="Узлы распорок:"/>
                        <TextBox Grid.Row="7" Grid.Column="2" Text="{Binding S_NodesDouble}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="8" Grid.Column="0" AttributeName="S_NodesChannel"/>
                        <Label Grid.Row="8" Grid.Column="1" Content="Узлы диафрагм:"/>
                        <TextBox Grid.Row="8" Grid.Column="2" Text="{Binding S_NodesChannel}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="9" Grid.Column="0" AttributeName="S_NodesExclude"/>
                        <Label Grid.Row="9" Grid.Column="1" Content="Исключить узлы (Для режима 2):"/>
                        <TextBox Grid.Row="9" Grid.Column="2" Text="{Binding S_NodesExclude}"/>

                        <TextBlock Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" Text="Материалы и профили планок" FontWeight="Bold" Margin="0,15,0,5"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="11" Grid.Column="0" AttributeName="S_Profile"/>
                        <Label Grid.Row="11" Grid.Column="1" Content="Профиль распорки:"/>
                        <TextBox Grid.Row="11" Grid.Column="2" Text="{Binding S_Profile}"/>
                        <UIControls:WpfProfileCatalog x:Name="StrutProfileCatalog" Grid.Row="11" Grid.Column="3" Width="30" Margin="0,3,0,3"
                                                      SelectClicked="StrutProfileCatalog_SelectClicked" SelectionDone="StrutProfileCatalog_SelectionDone"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="12" Grid.Column="0" AttributeName="D_Profile"/>
                        <Label Grid.Row="12" Grid.Column="1" Content="Профиль диафрагмы:"/>
                        <TextBox Grid.Row="12" Grid.Column="2" Text="{Binding D_Profile}"/>
                        <UIControls:WpfProfileCatalog x:Name="DiaphragmProfileCatalog" Grid.Row="12" Grid.Column="3" Width="30" Margin="0,3,0,3"
                                                      SelectClicked="DiaphragmProfileCatalog_SelectClicked" SelectionDone="DiaphragmProfileCatalog_SelectionDone"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="13" Grid.Column="0" AttributeName="S_Material"/>
                        <Label Grid.Row="13" Grid.Column="1" Content="Материал распорки:"/>
                        <TextBox Grid.Row="13" Grid.Column="2" Text="{Binding S_Material}"/>
                        <UIControls:WpfMaterialCatalog x:Name="StrutMaterialCatalog" Grid.Row="13" Grid.Column="3" Width="30" Margin="0,3,0,3"
                                                       SelectClicked="StrutMaterialCatalog_SelectClicked" SelectionDone="StrutMaterialCatalog_SelectionDone"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="14" Grid.Column="0" AttributeName="D_Material"/>
                        <Label Grid.Row="14" Grid.Column="1" Content="Материал диафрагмы:"/>
                        <TextBox Grid.Row="14" Grid.Column="2" Text="{Binding D_Material}"/>
                        <UIControls:WpfMaterialCatalog x:Name="DiaphragmMaterialCatalog" Grid.Row="14" Grid.Column="3" Width="30" Margin="0,3,0,3"
                                                       SelectClicked="DiaphragmMaterialCatalog_SelectClicked" SelectionDone="DiaphragmMaterialCatalog_SelectionDone"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <UIControls:WpfOkApplyModifyGetOnOffCancel Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,5,0,5"
            ApplyClicked="WpfOkApplyModifyGetOnOffCancel_ApplyClicked" 
            CancelClicked="WpfOkApplyModifyGetOnOffCancel_CancelClicked" 
            GetClicked="WpfOkApplyModifyGetOnOffCancel_GetClicked" 
            ModifyClicked="WpfOkApplyModifyGetOnOffCancel_ModifyClicked" 
            OkClicked="WpfOkApplyModifyGetOnOffCancel_OkClicked" 
            OnOffClicked="WpfOkApplyModifyGetOnOffCancel_OnOffClicked"/>
    </Grid>
</tsd:PluginWindowBase>