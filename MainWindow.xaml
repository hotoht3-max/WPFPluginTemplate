<tsd:PluginWindowBase
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Apibim.Plugins.BuiltUpColumn"
        xmlns:localUI="clr-namespace:Apibim.Plugins.BuiltUpColumn.UIControls"
        xmlns:tsd="clr-namespace:Tekla.Structures.Dialog;assembly=Tekla.Structures.Dialog"
        xmlns:UIControls="clr-namespace:Tekla.Structures.Dialog.UIControls;assembly=Tekla.Structures.Dialog" 
        x:Class="Apibim.Plugins.BuiltUpColumn.MainWindow"
        mc:Ignorable="d"
        Title="Сквозная колонна RAM (Alpha)" FontSize="14" Height="700" Width="1200">

    <Grid>
        <Grid.Resources>
            <Style TargetType="TextBox">
                <Setter Property="Height" Value="24"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Margin" Value="2"/>
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="Height" Value="24"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Margin" Value="2"/>
            </Style>
            <Style TargetType="Label">
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Margin" Value="2"/>
            </Style>
            <Style TargetType="UIControls:WpfFilterCheckBox">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="5,0"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <localUI:HeaderSystemControl Grid.Row="0" Margin="0,5,0,5"/>

        <TabControl Grid.Row="1" Margin="5">

            <TabItem Header="Общее">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="Габариты и ориентация" FontWeight="Bold" Margin="0,10,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="1" Grid.Column="0" AttributeName="Bcol"/>
                        <Label Grid.Row="1" Grid.Column="1" Content="Ширина колонны (Bcol):"/>
                        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Bcol}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="2" Grid.Column="0" AttributeName="Br_Rot"/>
                        <Label Grid.Row="2" Grid.Column="1" Content="Поворот ветвей (Br_Rot):"/>
                        <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding Br_Rot}"/>

                        <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Text="Высотные отметки" FontWeight="Bold" Margin="0,15,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="4" Grid.Column="0" AttributeName="Hcol_1"/>
                        <Label Grid.Row="4" Grid.Column="1" Content="Высота ветви вверх (Hcol_1):"/>
                        <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding Hcol_1}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="5" Grid.Column="0" AttributeName="Hcol_e1"/>
                        <Label Grid.Row="5" Grid.Column="1" Content="Глубина ветви вниз (Hcol_e1):"/>
                        <TextBox Grid.Row="5" Grid.Column="2" Text="{Binding Hcol_e1}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="6" Grid.Column="0" AttributeName="Hcol_e2"/>
                        <Label Grid.Row="6" Grid.Column="1" Content="Свободная зона снизу (Hcol_e2):"/>
                        <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding Hcol_e2}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="7" Grid.Column="0" AttributeName="Hcol_e3"/>
                        <Label Grid.Row="7" Grid.Column="1" Content="Свободная зона сверху (Hcol_e3):"/>
                        <TextBox Grid.Row="7" Grid.Column="2" Text="{Binding Hcol_e3}"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Решетка">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="Разбивка панелей" FontWeight="Bold" Margin="0,10,0,5"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="1" Grid.Column="0" AttributeName="L_StepMode"/>
                        <Label Grid.Row="1" Grid.Column="1" Content="Режим шага решетки:"/>
                        <ComboBox Grid.Row="1" Grid.Column="2" SelectedIndex="{Binding L_StepMode}">
                            <ComboBoxItem Content="0 - Равномерный"/>
                            <ComboBoxItem Content="1 - Ввод размеров (Массив)"/>
                            <ComboBoxItem Content="2 - Кол-во панелей и отметки"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="2" Grid.Column="0" AttributeName="L_StepText"/>
                        <Label Grid.Row="2" Grid.Column="1" Content="Массив / Отметки (или шаг):"/>
                        <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding L_StepText}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="3" Grid.Column="0" AttributeName="L_MinRemainder"/>
                        <Label Grid.Row="3" Grid.Column="1" Content="Мин. остаток (мм) [Для Реж.1]:"/>
                        <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding L_MinRemainder}" ToolTip="Если 0, принимается ширина колонны"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="4" Grid.Column="0" AttributeName="L_MergePanels"/>
                        <Label Grid.Row="4" Grid.Column="1" Content="Захватить панелей (шт) [Для Реж.1]:"/>
                        <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding L_MergePanels}" ToolTip="Сколько панелей сливаем? (Например: 2 = хвост + 1 нормальная)"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="5" Grid.Column="0" AttributeName="L_RemainPanels"/>
                        <Label Grid.Row="5" Grid.Column="1" Content="Разбить хвост на (шт) [Для Реж.1]:"/>
                        <TextBox Grid.Row="5" Grid.Column="2" Text="{Binding L_RemainPanels}" ToolTip="На сколько панелей разделить хвост (по умолч. 2)"/>

                        <TextBlock Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Text="Управление геометрией" FontWeight="Bold" Margin="0,15,0,5"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="7" Grid.Column="0" AttributeName="L_Invert"/>
                        <Label Grid.Row="7" Grid.Column="1" Content="Старт решетки:"/>
                        <ComboBox Grid.Row="7" Grid.Column="2" SelectedIndex="{Binding L_Invert}">
                            <ComboBoxItem Content="От левой ветви (По умолч.)"/>
                            <ComboBoxItem Content="От правой ветви (Инверсия)"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="8" Grid.Column="0" AttributeName="L_Exclude"/>
                        <Label Grid.Row="8" Grid.Column="1" Content="Удалить раскосы (напр. 1-3 5):"/>
                        <TextBox Grid.Row="8" Grid.Column="2" Text="{Binding L_Exclude}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="9" Grid.Column="0" AttributeName="L_HoldPhase"/>
                        <Label Grid.Row="9" Grid.Column="1" Content="Поведение при удалении:"/>
                        <ComboBox Grid.Row="9" Grid.Column="2" SelectedIndex="{Binding L_HoldPhase}">
                            <ComboBoxItem Content="0 - Продолжать зигзаг (Скрытый)"/>
                            <ComboBoxItem Content="1 - Сохранять стартовую ветвь"/>
                        </ComboBox>

                        <TextBlock Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" Text="Расцентровка узлов" FontWeight="Bold" Margin="0,15,0,5"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="11" Grid.Column="0" AttributeName="L_Rasc"/>
                        <Label Grid.Row="11" Grid.Column="1" Content="Базовая расцентровка:"/>
                        <TextBox Grid.Row="11" Grid.Column="2" Text="{Binding L_Rasc}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="12" Grid.Column="0" AttributeName="L_Rasc_Base"/>
                        <Label Grid.Row="12" Grid.Column="1" Content="Расцентровка базы (Узел 1):"/>
                        <TextBox Grid.Row="12" Grid.Column="2" Text="{Binding L_Rasc_Base}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="13" Grid.Column="0" AttributeName="L_Rasc_Top"/>
                        <Label Grid.Row="13" Grid.Column="1" Content="Расцентровка верха (Узел N):"/>
                        <TextBox Grid.Row="13" Grid.Column="2" Text="{Binding L_Rasc_Top}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="14" Grid.Column="0" AttributeName="L_RascOverrides"/>
                        <Label Grid.Row="14" Grid.Column="1" Content="Исключения (Узел:Вверх/Вниз):"/>
                        <TextBox Grid.Row="14" Grid.Column="2" Text="{Binding L_RascOverrides}"/>

                        <TextBlock Grid.Row="15" Grid.Column="1" Grid.ColumnSpan="2" Text="Параметры и позиционирование" FontWeight="Bold" Margin="0,15,0,5"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="16" Grid.Column="0" AttributeName="L_Type"/>
                        <Label Grid.Row="16" Grid.Column="1" Content="Тип решетки:"/>
                        <ComboBox Grid.Row="16" Grid.Column="2" SelectedIndex="{Binding L_Type}">
                            <ComboBoxItem Content="0 - Одинарная"/>
                            <ComboBoxItem Content="1 - Сдвоенная"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="17" Grid.Column="0" AttributeName="L_Preset"/>
                        <Label Grid.Row="17" Grid.Column="1" Content="Вариант (Пресет):"/>
                        <ComboBox Grid.Row="17" Grid.Column="2" SelectedIndex="{Binding L_Preset}">
                            <ComboBoxItem Content="0 - Не используется" Visibility="Collapsed"/>
                            <ComboBoxItem Content="1 - Полка по оси"/>
                            <ComboBoxItem Content="2 - Уголок по обушку (Слева)"/>
                            <ComboBoxItem Content="3 - Труба (По центру)"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="18" Grid.Column="0" AttributeName="L_Offset"/>
                        <Label Grid.Row="18" Grid.Column="1" Content="Доп. смещение:"/>
                        <TextBox Grid.Row="18" Grid.Column="2" Text="{Binding L_Offset}"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Планки">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="Настройки планок по зонам (Фон)" FontWeight="Bold" Margin="0,10,0,5"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="1" Grid.Column="0" AttributeName="S_Base_Preset"/>
                        <Label Grid.Row="1" Grid.Column="1" Content="Планка в базе [Узел 1]:"/>
                        <ComboBox Grid.Row="1" Grid.Column="2" SelectedIndex="{Binding S_Base_Preset}">
                            <ComboBoxItem Content="0 - Нет"/>
                            <ComboBoxItem Content="1 - Распорка (уголки)"/>
                            <ComboBoxItem Content="2 - Распорка с листом"/>
                            <ComboBoxItem Content="3 - Диафрагма (Тип 1)"/>
                            <ComboBoxItem Content="4 - Диафрагма (Тип 2)"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="2" Grid.Column="0" AttributeName="S_Top_Preset"/>
                        <Label Grid.Row="2" Grid.Column="1" Content="Планка в верхушке [Узел N]:"/>
                        <ComboBox Grid.Row="2" Grid.Column="2" SelectedIndex="{Binding S_Top_Preset}">
                            <ComboBoxItem Content="0 - Нет"/>
                            <ComboBoxItem Content="1 - Распорка (уголки)"/>
                            <ComboBoxItem Content="2 - Распорка с листом"/>
                            <ComboBoxItem Content="3 - Диафрагма (Тип 1)"/>
                            <ComboBoxItem Content="4 - Диафрагма (Тип 2)"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="3" Grid.Column="0" AttributeName="S_Splice_Preset"/>
                        <Label Grid.Row="3" Grid.Column="1" Content="Планки у стыков ветвей:"/>
                        <ComboBox Grid.Row="3" Grid.Column="2" SelectedIndex="{Binding S_Splice_Preset}">
                            <ComboBoxItem Content="0 - Нет"/>
                            <ComboBoxItem Content="1 - Распорка (уголки)"/>
                            <ComboBoxItem Content="2 - Распорка с листом"/>
                            <ComboBoxItem Content="3 - Диафрагма (Тип 1)"/>
                            <ComboBoxItem Content="4 - Диафрагма (Тип 2)"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="4" Grid.Column="0" AttributeName="S_KeyElev_Preset"/>
                        <Label Grid.Row="4" Grid.Column="1" Content="На ключевых отметках:"/>
                        <ComboBox Grid.Row="4" Grid.Column="2" SelectedIndex="{Binding S_KeyElev_Preset}" ToolTip="Срабатывает на отметках из списка шагов решетки">
                            <ComboBoxItem Content="0 - Нет"/>
                            <ComboBoxItem Content="1 - Распорка (уголки)"/>
                            <ComboBoxItem Content="2 - Распорка с листом"/>
                            <ComboBoxItem Content="3 - Диафрагма (Тип 1)"/>
                            <ComboBoxItem Content="4 - Диафрагма (Тип 2)"/>
                        </ComboBox>

                        <UIControls:WpfFilterCheckBox Grid.Row="5" Grid.Column="0" AttributeName="S_Preset"/>
                        <Label Grid.Row="5" Grid.Column="1" Content="Рядовые планки (по умолчанию):"/>
                        <ComboBox Grid.Row="5" Grid.Column="2" SelectedIndex="{Binding S_Preset}">
                            <ComboBoxItem Content="0 - Нет"/>
                            <ComboBoxItem Content="1 - Распорка (уголки)"/>
                            <ComboBoxItem Content="2 - Распорка с листом"/>
                            <ComboBoxItem Content="3 - Диафрагма (Тип 1)"/>
                            <ComboBoxItem Content="4 - Диафрагма (Тип 2)"/>
                        </ComboBox>

                        <TextBlock Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Text="Переопределение узлов (Каскад)" FontWeight="Bold" Margin="0,15,0,5"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="7" Grid.Column="0" AttributeName="S_NodesAngle"/>
                        <Label Grid.Row="7" Grid.Column="1" Content="Узлы уголков [Тип 1]:"/>
                        <TextBox Grid.Row="7" Grid.Column="2" Text="{Binding S_NodesAngle}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="8" Grid.Column="0" AttributeName="S_NodesAnglePlate"/>
                        <Label Grid.Row="8" Grid.Column="1" Content="Узлы уголков с листом [Тип 2]:"/>
                        <TextBox Grid.Row="8" Grid.Column="2" Text="{Binding S_NodesAnglePlate}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="9" Grid.Column="0" AttributeName="S_NodesD1"/>
                        <Label Grid.Row="9" Grid.Column="1" Content="Узлы диафрагм (Тип 1) [Тип 3]:"/>
                        <TextBox Grid.Row="9" Grid.Column="2" Text="{Binding S_NodesD1}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="10" Grid.Column="0" AttributeName="S_NodesD2"/>
                        <Label Grid.Row="10" Grid.Column="1" Content="Узлы диафрагм (Тип 2) [Тип 4]:"/>
                        <TextBox Grid.Row="10" Grid.Column="2" Text="{Binding S_NodesD2}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="11" Grid.Column="0" AttributeName="S_NodesExcludePlate"/>
                        <Label Grid.Row="11" Grid.Column="1" Content="Исключить листы (Тип 2 -> 1):"/>
                        <TextBox Grid.Row="11" Grid.Column="2" Text="{Binding S_NodesExcludePlate}"/>

                        <UIControls:WpfFilterCheckBox Grid.Row="12" Grid.Column="0" AttributeName="S_NodesExclude"/>
                        <Label Grid.Row="12" Grid.Column="1" Content="Глобально исключить узлы:" Foreground="DarkRed" FontWeight="SemiBold"/>
                        <TextBox Grid.Row="12" Grid.Column="2" Text="{Binding S_NodesExclude}"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Стыки ветвей">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <UIControls:WpfFilterCheckBox Grid.Row="0" Grid.Column="0" AttributeName="SplicesText"/>
                        <Label Grid.Row="0" Grid.Column="1" Content="Отметки стыков в модели (Z):" FontWeight="Bold"/>
                        <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding SplicesText}" ToolTip="Введите отметки через пробел (например: 6000 12000)"/>

                        <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="Уровень 1 (Базовый для всех стыков)" FontWeight="Bold" Foreground="#FF0055A4" Margin="0,15,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="2" Grid.Column="0" AttributeName="Splice1Component"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="3" Grid.Column="0" AttributeName="Splice1Preset"/>
                        <localUI:ComponentSelectorControl Grid.Row="2" Grid.RowSpan="2" Grid.Column="1" Grid.ColumnSpan="2" ComponentText="{Binding Splice1Component, Mode=TwoWay}" PresetText="{Binding Splice1Preset, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Text="Уровень 2 (Переопределить выбранные)" FontWeight="Bold" Margin="0,15,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="5" Grid.Column="0" AttributeName="Splice2Indexes"/>
                        <Label Grid.Row="5" Grid.Column="1" Content="Номера стыков (например: 2 4):"/>
                        <TextBox Grid.Row="5" Grid.Column="2" Text="{Binding Splice2Indexes}"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="6" Grid.Column="0" AttributeName="Splice2Component"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="7" Grid.Column="0" AttributeName="Splice2Preset"/>
                        <localUI:ComponentSelectorControl Grid.Row="6" Grid.RowSpan="2" Grid.Column="1" Grid.ColumnSpan="2" ComponentText="{Binding Splice2Component, Mode=TwoWay}" PresetText="{Binding Splice2Preset, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Text="Уровень 3 (Переопределить выбранные)" FontWeight="Bold" Margin="0,15,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="9" Grid.Column="0" AttributeName="Splice3Indexes"/>
                        <Label Grid.Row="9" Grid.Column="1" Content="Номера стыков:"/>
                        <TextBox Grid.Row="9" Grid.Column="2" Text="{Binding Splice3Indexes}"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="10" Grid.Column="0" AttributeName="Splice3Component"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="11" Grid.Column="0" AttributeName="Splice3Preset"/>
                        <localUI:ComponentSelectorControl Grid.Row="10" Grid.RowSpan="2" Grid.Column="1" Grid.ColumnSpan="2" ComponentText="{Binding Splice3Component, Mode=TwoWay}" PresetText="{Binding Splice3Preset, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="12" Grid.Column="1" Grid.ColumnSpan="2" Text="Уровень 4 (Переопределить выбранные)" FontWeight="Bold" Margin="0,15,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="13" Grid.Column="0" AttributeName="Splice4Indexes"/>
                        <Label Grid.Row="13" Grid.Column="1" Content="Номера стыков:"/>
                        <TextBox Grid.Row="13" Grid.Column="2" Text="{Binding Splice4Indexes}"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="14" Grid.Column="0" AttributeName="Splice4Component"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="15" Grid.Column="0" AttributeName="Splice4Preset"/>
                        <localUI:ComponentSelectorControl Grid.Row="14" Grid.RowSpan="2" Grid.Column="1" Grid.ColumnSpan="2" ComponentText="{Binding Splice4Component, Mode=TwoWay}" PresetText="{Binding Splice4Preset, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="16" Grid.Column="1" Grid.ColumnSpan="2" Text="Уровень 5 (Переопределить выбранные)" FontWeight="Bold" Margin="0,15,0,5"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="17" Grid.Column="0" AttributeName="Splice5Indexes"/>
                        <Label Grid.Row="17" Grid.Column="1" Content="Номера стыков:"/>
                        <TextBox Grid.Row="17" Grid.Column="2" Text="{Binding Splice5Indexes}"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="18" Grid.Column="0" AttributeName="Splice5Component"/>
                        <UIControls:WpfFilterCheckBox Grid.Row="19" Grid.Column="0" AttributeName="Splice5Preset"/>
                        <localUI:ComponentSelectorControl Grid.Row="18" Grid.RowSpan="2" Grid.Column="1" Grid.ColumnSpan="2" ComponentText="{Binding Splice5Component, Mode=TwoWay}" PresetText="{Binding Splice5Preset, Mode=TwoWay}"/>

                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Атрибуты">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="145"/>
                                <ColumnDefinition Width="165"/>
                                <ColumnDefinition Width="135"/>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="145"/>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

