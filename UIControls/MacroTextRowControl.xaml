<UserControl x:Class="Apibim.Plugins.BuiltUpColumn.UIControls.MacroTextRowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:teklaUI="clr-namespace:Tekla.Structures.Dialog.UIControls;assembly=Tekla.Structures.Dialog"
             x:Name="root">
    <Grid Margin="0,2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition SharedSizeGroup="CheckCol" Width="Auto" MinWidth="25"/>
            <ColumnDefinition SharedSizeGroup="LabelCol" Width="Auto" MinWidth="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <teklaUI:WpfFilterCheckBox x:Name="filterCb" Grid.Column="0" VerticalAlignment="Center" Margin="5,0"/>

        <Label Grid.Column="1" Content="{Binding LabelText, ElementName=root}" VerticalAlignment="Center" Margin="0,2"/>

        <TextBox Grid.Column="2" Text="{Binding Text, ElementName=root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                 Height="24" VerticalContentAlignment="Center" Margin="0,2"/>
    </Grid>
</UserControl>