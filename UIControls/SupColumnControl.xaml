<UserControl x:Class="Apibim.Plugins.BuiltUpColumn.UIControls.SupColumnControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:UIControls="clr-namespace:Tekla.Structures.Dialog.UIControls;assembly=Tekla.Structures.Dialog">
    <Expander Header="Настройки надколонника" IsExpanded="True" FontWeight="Bold" Foreground="#FF0055A4" Margin="0,10,0,0">
        <Grid Margin="0,5,0,0" TextElement.FontWeight="Normal" TextElement.Foreground="Black">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="25"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <UIControls:WpfFilterCheckBox Grid.Row="0" Grid.Column="0" AttributeName="NK_Mode" VerticalAlignment="Center"/>
            <Label Grid.Row="0" Grid.Column="1" Content="Положение надколонника:" VerticalAlignment="Center" Margin="0,2"/>
            <ComboBox Grid.Row="0" Grid.Column="2" SelectedIndex="{Binding NK_Mode}" VerticalAlignment="Center" Height="24" Margin="0,2">
                <ComboBoxItem Content="0 - Слева (по 1 ветви)"/>
                <ComboBoxItem Content="1 - Справа (по 2 ветви)"/>
                <ComboBoxItem Content="2 - По центру"/>
            </ComboBox>

            <UIControls:WpfFilterCheckBox Grid.Row="1" Grid.Column="0" AttributeName="NK_HeightType" VerticalAlignment="Center"/>
            <Label Grid.Row="1" Grid.Column="1" Content="Маршрутизация высоты:" VerticalAlignment="Center" Margin="0,2"/>
            <ComboBox Grid.Row="1" Grid.Column="2" SelectedIndex="{Binding NK_HeightType}" VerticalAlignment="Center" Height="24" Margin="0,2">
                <ComboBoxItem Content="0 - Длина хлыста"/>
                <ComboBoxItem Content="1 - По отметке верха (Z)"/>
            </ComboBox>

            <UIControls:WpfFilterCheckBox Grid.Row="2" Grid.Column="0" AttributeName="NK_Value" VerticalAlignment="Center"/>
            <Label Grid.Row="2" Grid.Column="1" Content="Высота надколонника (мм):" VerticalAlignment="Center" Margin="0,2"/>
            <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding NK_Value}" VerticalAlignment="Center" Height="24" Margin="0,2" VerticalContentAlignment="Center"/>

            <UIControls:WpfFilterCheckBox Grid.Row="3" Grid.Column="0" AttributeName="NK_Offset" VerticalAlignment="Center"/>
            <Label Grid.Row="3" Grid.Column="1" Content="Смещение оси внутрь (мм):" VerticalAlignment="Center" Margin="0,2"/>
            <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding NK_Offset}" VerticalAlignment="Center" Height="24" Margin="0,2" VerticalContentAlignment="Center"/>

            <UIControls:WpfFilterCheckBox Grid.Row="4" Grid.Column="0" AttributeName="NK_Rot" VerticalAlignment="Center"/>
            <Label Grid.Row="4" Grid.Column="1" Content="Поворот сечения (Градусы):" VerticalAlignment="Center" Margin="0,2"/>
            <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding NK_Rot}" VerticalAlignment="Center" Height="24" Margin="0,2" VerticalContentAlignment="Center"/>
        </Grid>
    </Expander>
</UserControl>