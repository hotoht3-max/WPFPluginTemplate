<UserControl x:Class="Apibim.Plugins.BuiltUpColumn.UIControls.HelpTooltipControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#007ACC" CornerRadius="10" Width="18" Height="18" Margin="5,0" Cursor="Help" ToolTipService.ShowDuration="30000" ToolTipService.InitialShowDelay="100">
        <TextBlock Text="?" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Border.ToolTip>
            <ToolTip>
                <StackPanel Margin="5">
                    <TextBlock Text="Синтаксис умных пресетов:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="• 1 3 5 — Применить пресет к узлам 1, 3, 5 (Смещение по умолчанию)"/>
                    <TextBlock Text="• 1-5 — Применить к диапазону с 1 по 5"/>
                    <TextBlock Text="• (1-4 6):25.5 — Узлам 1-4 и 6 жестко задать смещение 25.5 мм" FontWeight="Medium" Foreground="#005599"/>
                    <TextBlock Text="Комбинации поддерживаются, например: (1-4):20 5 6-8" Margin="0,5,0,0" FontStyle="Italic"/>
                </StackPanel>
            </ToolTip>
        </Border.ToolTip>
    </Border>
</UserControl>